programa {
  funcao inicio() {
     inteiro do, dr 

    escreva("Qual seu dividendo: ")
    leia(do)

    escreva("Qual seu divisor: ")
    leia(dr)
    
    escreva("\nSeu dividendo é: ", do)
    escreva("\nSeus divisor é: ", dr)
    escreva("\nSeu quociente é: ", do/ dr)
    escreva("\nSeus resto é: ", do% dr)
    
  }
}
