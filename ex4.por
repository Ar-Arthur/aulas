programa {
  funcao inicio() {
    inteiro l, c, v

    escreva("Qual a largura do terreno: ")
    leia(l)

    escreva("Qual o comprimento do terreno: ")
    leia(c)
    
    escreva("Qual o valor do terreno: ")
    leia(v)

    escreva("\nA area do terreno e de: ", l* c)
    escreva("\nO valor é: ", v)
  }
}
